# ============================================================
#  backend/.env.example — SOLO para desarrollo LOCAL sin Docker
#  (uvicorn app.main:app). Copiar a backend/.env y rellenar.
#
#  Para el DESPLIEGUE con Docker NO se usa este archivo: toda la
#  configuración va en el .env de la RAÍZ (ver .env.example raíz).
#
#  NUNCA commitear el archivo .env con valores reales.
# ============================================================

# --- SEGURIDAD ---
# Entorno: 'development' o 'production'. En 'production' algunas protecciones
# fallan-cerrado (reCAPTCHA sin clave rechaza) y los 500 no exponen detalle.
ENVIRONMENT=development
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
# OBLIGATORIO. La app NO arranca sin un valor real (no usar el placeholder).
SECRET_KEY=CHANGE_ME_genera_una_clave_aleatoria_de_64_bytes
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- BASE DE DATOS ---
# Aplicación (usuario NO-superusuario, sujeto a RLS)
SQLALCHEMY_DATABASE_URL=postgresql://app_user:CHANGE_ME@localhost:5432/saascrematorio
# Administración (superusuario para migraciones / bypass RLS)
DB_ADMIN_USER=postgres
DB_ADMIN_PASS=CHANGE_ME

# --- REDIS / RATE LIMITING ---
REDIS_URL=memory://
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_API=100/minute

# --- STORAGE ---
UPLOAD_DIR=app/static/storage
STATIC_DIR=app/static

# --- AUDIT ---
AUDIT_LOG_ENABLED=true

# --- R2 / CLOUDFLARE ---
R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET_NAME=CHANGE_ME
R2_BUCKET_BACKUPS=CHANGE_ME
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_DOMAIN=https://cdn.tu-dominio.com
USE_R2=false

# --- BACKUPS (CLOUDFLARE R2) ---
R2_ACCOUNT_ID_BACKUP=CHANGE_ME
R2_ACCESS_KEY_ID_BACKUP=CHANGE_ME
R2_SECRET_ACCESS_KEY_BACKUP=CHANGE_ME

# --- PAYMENTS (POLAR.SH) ---
POLAR_ACCESS_TOKEN=CHANGE_ME
POLAR_WEBHOOK_SECRET=CHANGE_ME
POLAR_SERVER=sandbox

# --- APP CONFIG ---
BASE_URL=http://localhost:3000
FRONTEND_URL=http://lvh.me:3000

# --- RECAPTCHA v3 ---
RECAPTCHA_SECRET_KEY=CHANGE_ME

# --- EMAIL (SMTP) ---
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM=no-reply@tu-dominio.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
