from app.api.v1.shared.health.router import router as health_router
from app.api.v1.shared.announcements.router import router as common_announcements_router

app.include_router(auth_router, prefix="/api/v1/shared/auth", tags=["Shared - Autenticación"])
app.include_router(notifications_router, prefix="/api/v1/shared/notifications", tags=["Shared - Notificaciones"])
app.include_router(uploads_router, prefix="/api/v1/shared/upload", tags=["Shared - Uploads"])
app.include_router(theme_router, prefix="/api/v1/shared/theme", tags=["Shared - Tema"])
app.include_router(shared_dashboard_router, prefix="/api/v1/shared/dashboard", tags=["Shared - Dashboard"])
app.include_router(health_router, prefix="/api/v1/shared/health", tags=["Shared - Salud"])
