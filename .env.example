# ============================================================================
#  .env.example (RAÍZ) — ARCHIVO ÚNICO de configuración para el despliegue Docker
#  Copiar a .env y rellenar con valores REALES. NUNCA commitear el .env real.
#
#  Este archivo alimenta TODO el stack vía docker-compose:
#    - Compose/infra   → sustitución ${VAR} (DB, dominios, red, pgadmin)
#    - Backend         → inyectadas al contenedor como variables de entorno
#    - Frontend        → las NEXT_PUBLIC_* se pasan como build args (se hornean
#                        en el bundle; son PÚBLICAS por diseño)
#
#  Nota: backend/.env y frontend-saas/.env solo se usan para desarrollo LOCAL
#  sin Docker (uvicorn / npm run dev). En el servidor manda ESTE archivo.
# ============================================================================


# ─────────────────────────────────────────────────────────────────────────
#  1. INFRAESTRUCTURA / COMPOSE
# ─────────────────────────────────────────────────────────────────────────

# PostgreSQL COMPARTIDO del VPS (contenedor existente, no lo levanta el compose)
POSTGRES_HOST=evolution_postgres        # nombre del contenedor de Postgres en la red docker
POSTGRES_PORT=5432
POSTGRES_DB=v3_saas
POSTGRES_USER=usuario_pro               # SUPERUSUARIO (migraciones + backups, ignora RLS)
POSTGRES_PASSWORD=CHANGE_ME

# Usuario de la APP (NO superusuario — el RLS se aplica sobre él)
APP_USER=vincer_app
APP_USER_PASSWORD=CHANGE_ME

# PgAdmin
PGADMIN_DEFAULT_EMAIL=admin@tu-dominio.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME

# Dominios (deben coincidir con el DNS y con nginx-proxy)
DOMAIN_MAIN=tu-dominio.com
DOMAIN_APP=app.tu-dominio.com
DOMAIN_ADMIN=admin.tu-dominio.com
DOMAIN_MEMORIALS=memorial.tu-dominio.com
DOMAIN_API=api.tu-dominio.com
DOMAIN_PGADMIN=pgadmin.tu-dominio.com

# nginx-proxy / Let's Encrypt (companion)
LETSENCRYPT_EMAIL=ssl@tu-dominio.com

# Red externa (la del reverse-proxy existente)
EXTERNAL_NETWORK=web_private_red_webapps


# ─────────────────────────────────────────────────────────────────────────
#  2. BACKEND (secretos de runtime — se inyectan al contenedor backend)
#     NO son públicos. Nunca se pasan al frontend.
# ─────────────────────────────────────────────────────────────────────────

# Entorno: 'production' oculta /docs, oculta detalle de errores 500 y activa
# protecciones fallar-cerrado (reCAPTCHA sin clave rechaza).
ENVIRONMENT=production

# OBLIGATORIO. Generar con:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_genera_una_clave_aleatoria_de_64_bytes
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Rate limiting (Redis lo inyecta el compose: redis://redis:6379/0)
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_API=100/minute

# Storage / audit
UPLOAD_DIR=app/static/storage
STATIC_DIR=app/static
AUDIT_LOG_ENABLED=true

# CORS (opcional, separado por comas; sin definir usa los defaults del código)
CORS_ORIGINS=

# Cloudflare R2 — archivos
USE_R2=true
R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET_NAME=CHANGE_ME
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_DOMAIN=https://cdn.tu-dominio.com

# Cloudflare R2 — backups (bucket aparte)
R2_BUCKET_BACKUPS=CHANGE_ME
R2_ACCOUNT_ID_BACKUP=CHANGE_ME
R2_ACCESS_KEY_ID_BACKUP=CHANGE_ME
R2_SECRET_ACCESS_KEY_BACKUP=CHANGE_ME

# Pagos (Polar.sh)
POLAR_ACCESS_TOKEN=CHANGE_ME
POLAR_WEBHOOK_SECRET=CHANGE_ME
POLAR_SERVER=production                 # 'production' o 'sandbox'

# reCAPTCHA v3 — clave SECRETA (backend)
RECAPTCHA_SECRET_KEY=CHANGE_ME

# Correo (SMTP; usar contraseña de aplicación de Gmail)
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM=no-reply@tu-dominio.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com


# ─────────────────────────────────────────────────────────────────────────
#  3. FRONTEND (build-time, NEXT_PUBLIC_* — se hornean en el bundle)
#     Son PÚBLICAS: nunca pongas aquí secretos del backend.
#     Las 3 primeras las deriva el compose de los DOMAIN_* de arriba.
# ─────────────────────────────────────────────────────────────────────────

# reCAPTCHA v3 — clave de SITIO (pública, distinta de la secreta del backend)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=CHANGE_ME

# Dominio público del R2 (para servir imágenes)
NEXT_PUBLIC_CLOUDFLARE_R2=xxxx.r2.dev

# URLs base públicas
NEXT_PUBLIC_TRACKING_BASE_URL=https://track.tu-dominio.com
NEXT_PUBLIC_MEMORIAL_BASE_URL=https://memorial.tu-dominio.com
NEXT_PUBLIC_WIDGET_BASE_URL=https://app.tu-dominio.com
NEXT_PUBLIC_VINZER_URL=https://tu-dominio.com
NEXT_PUBLIC_VINZER_SLOGAN=Innovación y sensibilidad en la gestión funeraria y memoriales.
