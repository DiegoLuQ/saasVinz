# ============================================================
#  .env.example (raíz) — Variables consumidas por Docker Compose (VPS)
#  Copiar a .env y rellenar con valores REALES.
#  NUNCA commitear el archivo .env con valores reales.
# ============================================================

# --- PostgreSQL: instancia compartida del VPS ---
# POSTGRES_HOST = nombre del contenedor de Postgres en la red docker.
POSTGRES_HOST=nombre_contenedor_postgres
POSTGRES_PORT=5432
POSTGRES_DB=nombre_base_datos

# Superusuario (admin / backups, ignora RLS).
POSTGRES_USER=superusuario
POSTGRES_PASSWORD=CHANGE_ME

# Usuario de la APP (RLS aplica — NO superusuario).
APP_USER=app_user
APP_USER_PASSWORD=CHANGE_ME

# --- PgAdmin ---
PGADMIN_DEFAULT_EMAIL=admin@tu-dominio.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME

# --- DOMINIOS (Producción) ---
DOMAIN_MAIN=tu-dominio.com
DOMAIN_APP=app.tu-dominio.com
DOMAIN_ADMIN=admin.tu-dominio.com
DOMAIN_MEMORIALS=pm.tu-dominio.com
DOMAIN_API=api.tu-dominio.com
DOMAIN_PGADMIN=pgadmin.tu-dominio.com

# --- nginx-proxy / Let's Encrypt (companion) ---
LETSENCRYPT_EMAIL=ssl@tu-dominio.com

# --- Red externa (la del reverse-proxy existente) ---
EXTERNAL_NETWORK=nombre_red_externa
